<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>VideoFlow - Premium Workflow</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:         #0a0d14;
      --surface:    #111522;
      --surface2:   #171d30;
      --surface3:   #1e253d;
      --border:     rgba(255,255,255,0.06);
      --border-md:  rgba(255,255,255,0.12);
      --border-lg:  rgba(255,255,255,0.20);
      --text:       #f1f5f9;
      --text-dim:   #94a3b8;
      --text-faint: #475569;
      --accent:     #3b82f6;
      --green:      #10b981;
      --yellow:     #f59e0b;
      --pink:       #ec4899;
      --purple:     #8b5cf6;
      --r-sm:       6px;
      --r-md:       10px;
      --r-lg:       16px;
      --font-body:  'Inter', sans-serif;
    }

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      line-height: 1.5;
    }

    .page {
      max-width: 640px;
      margin: 0 auto;
      padding: 0 20px 80px;
    }

    /* ── TOPBAR ── */
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 40px 0 24px;
      border-bottom: 1px solid var(--border);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-wordmark {
      font-size: 1.35rem;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .brand-wordmark .w-flow {
      color: var(--accent);
    }

    .brand-indicator {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 4px 10px;
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      border-radius: 99px;
    }

    .brand-indicator-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--green);
    }

    .brand-indicator-label {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: var(--green);
      text-transform: uppercase;
    }

    .topbar-meta {
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--text-dim);
    }

    /* ── PIPELINE ── */
    .pipeline {
      margin-top: 24px;
      display: flex;
      flex-direction: column;
    }

    .connector {
      display: flex;
      padding-left: 38px;
      height: 20px;
    }

    .connector-line {
      width: 2px;
      height: 100%;
      background: var(--border);
    }

    /* ── STEP CARD ── */
    .step {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 24px;
      display: flex;
      gap: 20px;
      position: relative;
      align-items: flex-start;
    }

    .step::after {
      content: '';
      position: absolute;
      left: 0; top: 24px; bottom: 24px;
      width: 3px;
      border-radius: 0 4px 4px 0;
    }

    .s-blue::after   { background: var(--accent); }
    .s-purple::after { background: var(--purple); }
    .s-green::after  { background: var(--green); }
    .s-yellow::after { background: var(--yellow); }
    .s-pink::after   { background: var(--pink); }

    /* ── STEP NUMBER ── */
    .step-num {
      flex-shrink: 0;
      width: 30px;
      height: 30px;
      border-radius: var(--r-sm);
      border: 1px solid var(--border-md);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--text-dim);
    }

    /* ── STEP BODY ── */
    .step-body { flex: 1; min-width: 0; }

    /* ── BADGE / TAG ── */
    .tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 3px 8px;
      border-radius: var(--r-sm);
      margin-bottom: 8px;
    }

    .tag-blue   { background: rgba(59, 130, 246, 0.1);  color: #60a5fa; border: 1px solid rgba(59, 130, 246, 0.2); }
    .tag-purple { background: rgba(139, 92, 246, 0.1); color: #a78bfa; border: 1px solid rgba(139, 92, 246, 0.2); }
    .tag-green  { background: rgba(16, 185, 129, 0.1);  color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
    .tag-yellow { background: rgba(245, 158, 11, 0.1);  color: #fbbf24; border: 1px solid rgba(245, 158, 11, 0.2); }
    .tag-pink   { background: rgba(236, 72, 153, 0.1);  color: #f472b6; border: 1px solid rgba(236, 72, 153, 0.2); }

    /* ── STEP TITLE & HINT ── */
    .step-title {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 4px;
    }

    .step-hint {
      font-size: 0.85rem;
      color: var(--text-dim);
      line-height: 1.5;
    }

    /* ── ACTION BUTTONS ── */
    .actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: var(--r-md);
      font-size: 0.85rem;
      font-weight: 600;
      cursor: pointer;
      border: 1px solid color-mix(in srgb, var(--cc) 25%, transparent);
      background: color-mix(in srgb, var(--cc) 10%, transparent);
      color: var(--cc);
      text-decoration: none;
      transition: all 0.15s ease;
    }

    .btn:hover {
      background: color-mix(in srgb, var(--cc) 20%, transparent);
      border-color: color-mix(in srgb, var(--cc) 50%, transparent);
      transform: translateY(-1px);
    }

    .btn svg { flex-shrink: 0; display: block; }

    /* ── AI BUTTONS SECTION ── */
    .ai-section {
      margin-top: 16px;
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
      padding: 16px;
    }

    .ai-section-label {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: var(--text-dim);
      margin-bottom: 12px;
    }

    .ai-btns { display: flex; flex-wrap: wrap; gap: 10px; }

    /* ── PLATFORM LIST ── */
    .platforms { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }

    .plat-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px 16px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: var(--r-md);
    }

    .plat-icon {
      width: 32px; height: 32px;
      border-radius: var(--r-sm);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .plat-name {
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text);
    }

    .plat-sub {
      font-size: 0.75rem;
      color: var(--text-dim);
    }

    .plat-info {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
  </style>
</head>
<body>
<div class="page">

  <div class="topbar">
    <div class="brand">
      <div class="brand-wordmark">
        <span class="w-video">Video</span><span class="w-flow">Flow</span>
      </div>
      <div class="brand-indicator">
        <div class="brand-indicator-dot"></div>
        <span class="brand-indicator-label">Live</span>
      </div>
    </div>
    <div class="topbar-meta">Quy trình sản xuất</div>
  </div>

  <div class="pipeline">

    <div class="step s-blue">
      <div class="step-num">01</div>
      <div class="step-body">
        <div class="tag tag-blue">Nguồn</div>
        <div class="step-title">Tìm video</div>
        <div class="step-hint">Duyệt và chọn video trending trên Douyin.</div>
        <div class="actions">
          <a class="btn" style="--cc:#6fa0f8" onclick="go('https://www.douyin.com/jingxuan','dy')" href="javascript:void(0)">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Douyin
          </a>
        </div>
      </div>
    </div>

    <div class="connector"><div class="connector-line"></div></div>

    <div class="step s-purple">
      <div class="step-num">02</div>
      <div class="step-body">
        <div class="tag tag-purple">Sub</div>
        <div class="step-title">Tách sub cứng</div>
        <div class="step-hint">Trích xuất phụ đề từ video gốc.</div>
        <div class="actions">
          <a class="btn" style="--cc:#b09cfb" onclick="go('https://subtitleextractor.com/dashboard','sub')" href="javascript:void(0)">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/>
              <polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
            </svg>
            Subtitle Extractor
          </a>
        </div>

        <div class="ai-section">
          <div class="ai-section-label">
            <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <path d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20"/>
            </svg>
            Dịch sub
          </div>
          <div class="ai-btns">
            <a class="btn" style="--cc:#7baef8" onclick="go('https://gemini.google.com/app','gemini')" href="javascript:void(0)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2L9.5 9.5 2 12l7.5 2.5L12 22l2.5-7.5L22 12l-7.5-2.5z"/>
              </svg>
              Gemini
            </a>
            <a class="btn" style="--cc:#d4956a" onclick="go('https://claude.ai/new','claude')" href="javascript:void(0)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M12 3c-1 5-4.8 7-9 9 4.2 2 8 4 9 9 1-5 4.8-7 9-9-4.2-2-8-4-9-9z"/>
              </svg>
              Claude
            </a>
            <a class="btn" style="--cc:#4cba80" onclick="go('https://chatgpt.com/','gpt')" href="javascript:void(0)">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.2 10a7.9 7.9 0 00-.8-5.1A8.1 8.1 0 005.1 6.8 6 6 0 001.8 11a6 6 0 00.7 4.4 7.9 7.9 0 00.8 5.1A8.1 8.1 0 0018.9 17.2 6 6 0 0022.2 13a6 6 0 00-.1-3zm-9.7 8.7l-1.4-.8 1.8-3h-3.6L11 12.2l2-3.4 1.4.8-1.8 3H16l-1.7 2.7-1.8 3.4z"/>
              </svg>
              ChatGPT
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="connector"><div class="connector-line"></div></div>

    <div class="step s-green">
      <div class="step-num">03</div>
      <div class="step-body">
        <div class="tag tag-green">Edit</div>
        <div class="step-title">Edit — CapCut</div>
        <div class="step-hint">Chỉnh sửa video trên CapCut.</div>
      </div>
    </div>

    <div class="connector"><div class="connector-line"></div></div>

    <div class="step s-yellow">
      <div class="step-num">04</div>
      <div class="step-body">
        <div class="tag tag-yellow">Hoàn thiện</div>
        <div class="step-title">Fix bug &amp; Chèn nhạc</div>
        <div class="step-hint">Kiểm tra lỗi, thêm nhạc nền phù hợp.</div>
      </div>
    </div>

    <div class="connector"><div class="connector-line"></div></div>

    <div class="step s-pink">
      <div class="step-num">05</div>
      <div class="step-body">
        <div class="tag tag-pink">Đăng</div>
        <div class="step-title">Đăng video</div>
        <div class="step-hint">Đăng lên các nền tảng.</div>

        <div class="platforms">
          <div class="plat-row">
            <div class="plat-icon" style="background:rgba(240,80,80,0.10)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#f06060">
                <path d="M23.5 6.2a3 3 0 00-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5a3 3 0 00-2.1 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 002.1 2.1C4.5 20.4 12 20.4 12 20.4s7.5 0 9.4-.5a3 3 0 002.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.8 15.6V8.4l6.3 3.6-6.3 3.6z"/>
              </svg>
            </div>
            <div class="plat-info">
              <div class="plat-name">YouTube</div>
              <div class="plat-sub">youtube.com</div>
            </div>
            <a class="btn" style="--cc:#f06060; font-size:0.75rem; padding:6px 14px; margin-left:auto" onclick="go('https://www.youtube.com/','yt')" href="javascript:void(0)">Mở →</a>
          </div>

          <div class="plat-row">
            <div class="plat-icon" style="background:rgba(75,140,245,0.10)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#5b95f0">
                <path d="M24 12.1C24 5.4 18.6 0 12 0S0 5.4 0 12.1c0 6 4.4 11 10.1 11.9v-8.4H7.1v-3.5h3V9.4c0-3 1.8-4.6 4.5-4.6 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9v2.3h3.4l-.5 3.5H14v8.4C19.6 23.1 24 18.1 24 12.1z"/>
              </svg>
            </div>
            <div class="plat-info">
              <div class="plat-name">Facebook</div>
              <div class="plat-sub">facebook.com</div>
            </div>
            <a class="btn" style="--cc:#5b95f0; font-size:0.75rem; padding:6px 14px; margin-left:auto" onclick="go('https://www.facebook.com/','fb')" href="javascript:void(0)">Mở →</a>
          </div>

          <div class="plat-row">
            <div class="plat-icon" style="background:rgba(39,210,147,0.10)">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#27d294">
                <path d="M19.6 3.3A4.8 4.8 0 0115 0h-3.5v16.4a2.9 2.9 0 01-2.9 2.5 2.9 2.9 0 01-2.9-2.9 2.9 2.9 0 012.9-2.9c.3 0 .6 0 .8.1V9.6a6.4 6.4 0 00-.8-.1 6.4 6.4 0 00-6.4 6.4 6.4 6.4 0 006.4 6.4 6.4 6.4 0 006.4-6.4V8.2a8.2 8.2 0 004.8 1.5V6.3a4.8 4.8 0 01-3.2-3z"/>
              </svg>
            </div>
            <div class="plat-info">
              <div class="plat-name">TikTok</div>
              <div class="plat-sub">tiktok.com</div>
            </div>
            <a class="btn" style="--cc:#27d294; font-size:0.75rem; padding:6px 14px; margin-left:auto" onclick="go('https://www.tiktok.com/','tt')" href="javascript:void(0)">Mở →</a>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
const tabs = {};
function go(url, key) {
  try {
    if (tabs[key] && !tabs[key].closed) { tabs[key].focus(); }
    else { tabs[key] = window.open(url, '_blank'); }
  } catch(e) { window.open(url, '_blank'); }
}
</script>
</body>
</html>
